---
import { SITE } from '../data/site.js';
---

<!-- Sticky contact bar — mobile only (hidden on desktop via CSS) -->
<div class="sticky-bar" role="complementary" aria-label="ปุ่มติดต่อด่วน">
  <a href={SITE.lineHref} class="sticky-bar__btn sticky-bar__btn--line" aria-label={`ทัก LINE ${SITE.lineId}`} data-track-event="click_line">
    <!-- LINE icon -->
    <svg class="sticky-bar__icon" viewBox="0 0 40 40" fill="none" aria-hidden="true">
      <rect width="40" height="40" rx="10" fill="white" fill-opacity="0.22"/>
      <path d="M20 8C13.37 8 8 12.6 8 18.28c0 4.18 2.78 7.83 6.93 9.87-.3 1.12-1.1 4.07-1.26 4.7-.2.78.29 1.08.85.7.44-.29 5.83-3.86 7.43-4.97.34.05.68.07 1.05.07 6.63 0 12-4.6 12-10.27C35 12.6 26.63 8 20 8z" fill="white"/>
      <path d="M16 21v-5.5h1.3V20h2.5V21H16zm4.2 0v-5.5h1.3V21h-1.3zm2 0v-5.5h1.3l2.5 3.5v-3.5h1.3V21h-1.3l-2.5-3.5V21h-1.3zm-8.7-5.5h3.8V16.7h-1.25V21h-1.3v-4.3H13.5v-1.2z" fill="#06C755"/>
    </svg>
    <span class="sticky-bar__text">
      <strong>ส่งรูปประเมินฟรี</strong>
      <small>{SITE.lineId}</small>
    </span>
  </a>

  <a href={SITE.phoneHref} class="sticky-bar__btn sticky-bar__btn--phone" aria-label={`โทร ${SITE.phone}`} data-track-event="click_phone">
    <!-- Phone icon -->
    <svg class="sticky-bar__icon" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.3.2 2.5.6 3.6.1.3 0 .7-.2 1L6.6 10.8z" fill="white"/>
    </svg>
    <span class="sticky-bar__text">
      <strong>โทรเลย</strong>
      <small>{SITE.phone}</small>
    </span>
  </a>
</div>

<style>
  .sticky-bar {
    display: none; /* ซ่อนบน desktop */
  }

  @media (max-width: 767px) {
    .sticky-bar {
      display: flex;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      /* รองรับ safe area ของ iPhone มีรอยบาก */
      padding-bottom: env(safe-area-inset-bottom, 0px);
      box-shadow: 0 -3px 18px rgba(13, 21, 38, 0.18);
    }

    .sticky-bar__btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 10px;
      padding: 10px 12px;
      min-height: 60px;
      text-decoration: none;
      transition: filter 0.15s ease;
      -webkit-tap-highlight-color: transparent;
    }
    .sticky-bar__btn:hover { text-decoration: none; filter: brightness(1.08); }
    .sticky-bar__btn:active { filter: brightness(0.92); }

    /* LINE — สีเขียว LINE */
    .sticky-bar__btn--line {
      background: #06c755;
      color: #fff;
      /* LINE ให้พื้นที่ 60% เพราะเป็น CTA หลัก */
      flex: 1.4;
    }

    /* โทร — สีน้ำเงินแบรนด์ */
    .sticky-bar__btn--phone {
      background: var(--volt);
      color: #fff;
      /* กั้น divider บาง ๆ ระหว่างสองปุ่ม */
      border-left: 1px solid rgba(255 255 255 / 0.25);
    }

    .sticky-bar__icon {
      width: 34px;
      height: 34px;
      flex-shrink: 0;
    }

    .sticky-bar__text {
      display: flex;
      flex-direction: column;
      line-height: 1.2;
    }
    .sticky-bar__text strong {
      font-family: var(--font-display);
      font-size: 0.95rem;
      font-weight: 700;
      letter-spacing: 0.01em;
    }
    .sticky-bar__text small {
      font-size: 0.75rem;
      opacity: 0.88;
      font-weight: 400;
    }
  }
</style>
