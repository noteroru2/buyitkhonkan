---
// แถบวิ่งสไตล์กระดานราคา — ลายเซ็นของเว็บ
const items = [
  'ประเมินตามรุ่นและสภาพ',
  'ส่งรูปผ่าน LINE',
  'นัดรับตามคิวงาน',
  'ชำระหลังตรวจสอบและตกลงราคา',
  'บริการในจังหวัดขอนแก่น',
];
const row = items.map((t) => `▲ ${t}`).join('   ');
---

<div class="ticker-wrapper">
  <div class="ticker-track">
    <span>{row}</span>
    <span aria-hidden="true">{row}</span>
  </div>
</div>

<style>
  .ticker-wrapper {
    background: #ffb020; /* var(--cash) */
    color: #0d1526; /* var(--ink) */
    width: 100%;
    max-width: 100%;
    overflow: hidden;
    contain: layout paint;
    border-top: 2px solid #0d1526;
    border-bottom: 2px solid #0d1526;
  }
  .ticker-track {
    display: flex;
    width: max-content;
    animation: slide 30s linear infinite;
  }
  .ticker-track span {
    font-family: 'Chakra Petch', 'Anuphan', sans-serif;
    font-weight: 600;
    font-size: 0.9rem;
    white-space: pre;
    padding: 9px 1.5ch 9px 0;
  }
  @keyframes slide {
    to { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .ticker-track {
      animation: none;
    }
  }
</style>
