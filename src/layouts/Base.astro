---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyBar from '../components/StickyBar.astro';
import { SITE } from '../data/categories.js';

const {
  title,
  description,
  jsonLd = [],           // JSON-LD เพิ่มเติมของแต่ละหน้า (array)
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;

// LocalBusiness schema — ใส่ทุกหน้า ช่วย Google เข้าใจว่าเป็นธุรกิจท้องถิ่นในขอนแก่น
const localBusiness = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: SITE.legalName,
  alternateName: SITE.name,
  description: 'รับซื้อสินค้าไอทีทุกประเภทในจังหวัดขอนแก่น โน้ตบุ๊ค มือถือ คอมพิวเตอร์ กล้อง เครื่องเกม ประเมินราคาฟรี จ่ายเงินสดทันที บริการรับถึงที่',
  url: Astro.site?.href,
  telephone: SITE.phone,
  priceRange: '฿฿',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'ขอนแก่น',
    addressRegion: 'ขอนแก่น',
    postalCode: '40000',
    addressCountry: 'TH',
  },
  areaServed: SITE.areas.map((a) => ({ '@type': 'City', name: `อำเภอ${a}` })),
  openingHours: 'Mo-Su 09:00-19:30',
  email: SITE.email,
};

const allJsonLd = [localBusiness, ...jsonLd];
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Open Graph / Social -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="th_TH" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />

    <!-- ฟอนต์: โหลดเฉพาะ weight ที่ใช้จริง เพื่อความเบา -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anuphan:wght@400;500;600&family=Chakra+Petch:wght@600;700&display=swap"
      rel="stylesheet"
    />

    {allJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
    <StickyBar />
  </body>
</html>

<style is:global>
  /* เพิ่มพื้นที่ล่างบน mobile เพื่อไม่ให้ sticky bar ทับ footer */
  @media (max-width: 767px) {
    body {
      padding-bottom: calc(60px + env(safe-area-inset-bottom, 0px));
    }
  }
</style>
