---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StickyBar from '../components/StickyBar.astro';
import { SITE } from '../data/site.js';

const {
  title,
  description,
  jsonLd = [],
  ogImage = '/images/og/default-og.png',
  ogImageAlt = 'WINNER IT รับซื้อสินค้าไอทีในจังหวัดขอนแก่น',
  robots,
  stickyVariant = 'default',
  /** ใส่ Organization entity เฉพาะหน้าแรก / About / Contact */
  includeOrganization = false,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || '';
const ogImageUrl = new URL(ogImage, Astro.site).href;
const gtmId = import.meta.env.PUBLIC_GTM_ID;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;

const organization = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${siteUrl}/#organization`,
  name: SITE.legalName,
  alternateName: [SITE.name, SITE.company],
  description: SITE.serviceModel,
  url: `${siteUrl}/`,
  logo: `${siteUrl}/favicon.svg`,
  image: ogImageUrl,
  telephone: SITE.phone,
  email: SITE.email,
  priceRange: '฿฿',
  address: {
    '@type': 'PostalAddress',
    addressRegion: SITE.region,
    addressCountry: SITE.country,
  },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: `จังหวัด${SITE.region}`,
  },
  parentOrganization: {
    '@type': 'Organization',
    name: SITE.company,
  },
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: SITE.phone,
      contactType: 'customer service',
      availableLanguage: ['Thai'],
      areaServed: `จังหวัด${SITE.region}`,
    },
  ],
};

const website = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${siteUrl}/#website`,
  name: SITE.name,
  url: `${siteUrl}/`,
  publisher: { '@id': `${siteUrl}/#organization` },
  inLanguage: 'th-TH',
};

const allJsonLd = includeOrganization
  ? [organization, website, ...jsonLd]
  : jsonLd;
---

<!doctype html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    {robots && <meta name="robots" content={robots} />}
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content="th_TH" />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    {gtmId && (
      <script set:html={`window.dataLayer=window.dataLayer||[];window.dataLayer.push({'gtm.start':new Date().getTime(),event:'gtm.js'});`} />
    )}
    {gtmId && (
      <script async src={`https://www.googletagmanager.com/gtm.js?id=${gtmId}`}></script>
    )}

    {allJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}
  </head>
  <body>
    {gtmId && (
      <noscript>
        <iframe src={`https://www.googletagmanager.com/ns.html?id=${gtmId}`} height="0" width="0" style="display:none;visibility:hidden"></iframe>
      </noscript>
    )}
    <a class="skip-link" href="#main-content">ข้ามไปยังเนื้อหาหลัก</a>
    <Header />
    <slot />
    <Footer />
    <StickyBar variant={stickyVariant} />
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      const pageType = document.querySelector('main')?.classList.contains('detail-page')
        ? 'detail'
        : document.querySelector('article.post') ? 'article' : location.pathname === '/' ? 'home' : 'static';
      window.trackConversion = (eventName, parameters = {}) => {
        if (!eventName || typeof eventName !== 'string') return;
        window.dataLayer.push({
          event: eventName,
          page_path: location.pathname,
          page_type: pageType,
          device_context: matchMedia('(max-width: 900px)').matches ? 'mobile' : 'desktop',
          ...parameters,
        });
      };
      document.addEventListener('click', (event) => {
        const target = event.target instanceof Element ? event.target.closest('a') : null;
        if (!target) return;

        const href = target.getAttribute('href') || '';
        const explicitEvent = target.getAttribute('data-track-event');
        const isHero = Boolean(target.closest('.hero, .cat-hero'));
        const legacyEventMap = {
          click_line: isHero ? 'hero_line_click' : 'line_click',
          click_phone: isHero ? 'hero_phone_click' : 'phone_click',
        };
        const eventName = legacyEventMap[explicitEvent] || explicitEvent || (href.includes('line.me') ? 'line_click' : href.startsWith('tel:') ? 'phone_click' : '');
        if (!eventName) return;
        window.trackConversion(eventName, {
          link_url: href.startsWith('tel:') ? 'tel:' : href.includes('line.me') ? 'line' : href,
          cta_location: target.getAttribute('data-cta-location') || 'content',
          item_category: target.getAttribute('data-item-category') || undefined,
          area_name: target.getAttribute('data-area-name') || undefined,
        });
      });
    </script>
  </body>
</html>

<style is:global>
  .skip-link {
    position: fixed;
    left: 16px;
    top: 12px;
    z-index: 2000;
    transform: translateY(-140%);
    background: var(--color-navy);
    color: #fff;
    border: 2px solid var(--color-accent);
    border-radius: var(--radius-sm);
    padding: 10px 14px;
    font-family: var(--font-display);
    font-weight: 700;
  }
  .skip-link:focus {
    transform: translateY(0);
    text-decoration: none;
  }
  @media (max-width: 767px) {
    body {
      padding-bottom: calc(60px + env(safe-area-inset-bottom, 0px));
    }
  }
</style>
