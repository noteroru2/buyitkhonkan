---
import Base from '../layouts/Base.astro';
import Ticker from '../components/Ticker.astro';
import { SITE, CATEGORIES } from '../data/categories.js';
import { BRAND_PAGES } from '../data/brandPages.js';
import { MODEL_PAGES } from '../data/modelPages.js';
import { CONDITION_PAGES } from '../data/conditionPages.js';
import { LOCAL_PAGES, LOCAL_NAP } from '../data/localPages.js';

export function getStaticPaths() {
  return [
    ...CATEGORIES.map((c) => ({ params: { slug: c.slug }, props: { cat: c, kind: 'category' } })),
    ...BRAND_PAGES.map((brand) => ({ params: { slug: brand.path }, props: { brand, kind: 'brand' } })),
    ...MODEL_PAGES.map((model) => ({ params: { slug: model.path }, props: { model, kind: 'model' } })),
    ...CONDITION_PAGES.map((condition) => ({ params: { slug: condition.path }, props: { condition, kind: 'condition' } })),
    ...LOCAL_PAGES.map((localPage) => ({ params: { slug: localPage.path }, props: { localPage, kind: 'local' } })),
  ];
}

const { cat, brand, model, condition, localPage, kind = 'category' } = Astro.props;
const sec = cat ? CATEGORIES.find((c) => c.slug === cat.secondary) : null;
const others = cat ? CATEGORIES.filter((c) => c.slug !== cat.slug) : [];
const clusterLinks = (cat?.cluster || [])
  .map((slug) => CATEGORIES.find((c) => c.slug === slug))
  .filter(Boolean);
const siteUrl = Astro.site?.href?.replace(/\/$/, '') || '';
const detail = brand || model || condition || localPage;
const pageTitle = cat?.title || detail.title;
const pageDesc = cat?.desc || detail.desc;
const detailPrimary = model ? CATEGORIES.find((c) => c.slug === model.primaryCategory) : null;
const detailCategories = (brand?.categories || condition?.applies || localPage?.primary || [])
  .map((slug) => CATEGORIES.find((c) => c.slug === slug))
  .filter(Boolean);
const relatedBrands = (model?.related || [])
  .map((slug) => BRAND_PAGES.find((b) => b.slug === slug))
  .filter(Boolean);
const relatedModels = [
  ...(brand?.relatedModels || []),
  ...(model?.related || []),
]
  .map((slug) => MODEL_PAGES.find((m) => m.slug === slug))
  .filter(Boolean);

const breadcrumb = cat ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: `${siteUrl}/` },
    {
      '@type': 'ListItem',
      position: 2,
      name: `${cat.kw} ขอนแก่น`,
      item: `${siteUrl}/${cat.slug}/`,
    },
  ],
} : null;

const detailBreadcrumb = detail ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'หน้าแรก', item: `${siteUrl}/` },
    {
      '@type': 'ListItem',
      position: 2,
      name: detail.h1,
      item: `${siteUrl}${Astro.url.pathname}`,
    },
  ],
} : null;

const serviceLd = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: cat ? `${cat.kw} ขอนแก่น` : detail.h1,
  description: pageDesc,
  url: `${siteUrl}${Astro.url.pathname}`,
  provider: { '@id': `${siteUrl}/#organization` },
  areaServed: {
    '@type': 'AdministrativeArea',
    name: `จังหวัด${SITE.region}`,
  },
  serviceType: 'รับซื้อสินค้าไอทีมือสอง',
};

const faqLd = cat ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: cat.faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;

const jsonLd = cat ? [breadcrumb, serviceLd, faqLd] : [detailBreadcrumb, serviceLd];
---

<Base title={pageTitle} description={pageDesc} jsonLd={jsonLd}>
  {cat ? (
    <main id="main-content" class="article">
    <section class="cat-hero">
      <div class="container">
        <nav class="crumb" aria-label="breadcrumb">
          <a href="/">หน้าแรก</a> <span>/</span> {cat.kw} ขอนแก่น
        </nav>
        <p class="cat-hero__icon" aria-hidden="true">{cat.icon}</p>
        <h1>{cat.h1}</h1>
        {cat.intro.map((p) => <p class="lede">{p}</p>)}
        <p class="lede lede--soft">{SITE.serviceModel}</p>
        <div class="cta-row">
          <a href={SITE.lineHref} class="btn btn--line" data-track-event="click_line">ส่งรูปประเมินฟรี LINE {SITE.lineId}</a>
          <a href={SITE.phoneHref} class="btn btn--ghost" data-track-event="click_phone">โทร {SITE.phone}</a>
        </div>
      </div>
    </section>

    <Ticker />

    <div class="container article__body">
      <h2>ทำไมคนขอนแก่นเลือกขาย{cat.name}กับ WINNER IT</h2>
      {cat.why.map((p) => <p>{p}</p>)}
      <p>
        นอกจากหมวดนี้ เรายัง<a href="/">รับซื้อสินค้าไอที ขอนแก่น</a>ครบหลายประเภทในที่เดียว
        มีของหลายหมวดปนกันก็ส่งประเมินพร้อมกันได้ในแชทเดียว
      </p>

      <h2>{cat.kw}อะไรบ้าง — รุ่น ยี่ห้อ และสภาพที่ประเมินได้</h2>
      {cat.sub.map((s) => (
        <>
          <h3>{s.h}</h3>
          <p>{s.p}</p>
        </>
      ))}

      <h2>ราคา{cat.kw}มือสอง ประเมินจากอะไรบ้าง</h2>
      <p>{cat.price}</p>
      {cat.priceRows && (
        <div class="price-box" aria-label={`ตารางราคา${cat.kw}มือสอง`}>
          <div class="price-box__head">
            <h3>ตารางราคา{cat.name}มือสองโดยประมาณ</h3>
            <p>อัปเดตล่าสุด {cat.updatedAt}</p>
          </div>
          <div class="price-table-wrap">
            <table class="price-table">
              <thead>
                <tr>
                  <th>กลุ่มรุ่น / สินค้า</th>
                  <th>ช่วงราคาประเมิน</th>
                  <th>หมายเหตุ</th>
                </tr>
              </thead>
              <tbody>
                {cat.priceRows.map((row) => (
                  <tr>
                    <td>{row.item}</td>
                    <td>{row.range}</td>
                    <td>{row.note}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      )}
      <p>
        ราคาที่แจ้งเป็นราคาอ้างอิงเบื้องต้น ไม่ใช่ราคาสุดท้ายจนกว่าจะตรวจสภาพจริง
        และอาจเปลี่ยนตามรุ่นย่อย สภาพ อุปกรณ์ ตำหนิ และราคาตลาด ณ วันที่ตรวจสอบ
      </p>
      <p>
        แหล่งอ้างอิงเพิ่มเติม: <a href={cat.ext.url} target="_blank" rel="noopener">{cat.ext.text}</a>
      </p>

      <h2>ขั้นตอนขาย{cat.name}กับ WINNER IT</h2>
      <p>
        ขั้นแรก ถ่ายรูป{cat.name}ของคุณให้เห็นสภาพรอบตัวเครื่องและจุดตำหนิถ้ามี
        ส่งเข้าไลน์ {SITE.lineId} พร้อมแจ้งรุ่นและอุปกรณ์ที่มีครบ
        ขั้นที่สอง หลังได้รับข้อมูลครบ ทีมงานจะแจ้งราคาเบื้องต้นตามลำดับคิวในเวลาทำการ ({SITE.hours})
        ตัวเลขนี้ไม่ผูกมัด ไม่พอใจก็ปฏิเสธได้ทันที
        ขั้นสุดท้าย นัดจุดรับที่สะดวกหรือให้ทีมงานไปรับถึงที่
        ตรวจสภาพต่อหน้าแล้วรับเงินสดหรือโอนทันที
        พื้นที่และเวลานัดรับขึ้นอยู่กับตารางงานของทีมงานในแต่ละวัน
      </p>
      <p>
        อยากเตรียมเครื่องให้พร้อม อ่านเทคนิคได้ที่
        <a href={cat.article.href}>{cat.article.text}</a>
      </p>

      {cat.caseStudy && (
        <>
          <h2>เคสรับซื้อจริงของ{cat.name}ในขอนแก่น</h2>
          <div class="case-study">
            <p class="case-study__meta">{cat.caseStudy.date} · {cat.caseStudy.area}</p>
            <h3>{cat.caseStudy.title}</h3>
            <p>{cat.caseStudy.detail}</p>
            <p><strong>ผลลัพธ์:</strong> {cat.caseStudy.result}</p>
          </div>
        </>
      )}

      <h2>พื้นที่ให้บริการ{cat.kw}ในจังหวัดขอนแก่น</h2>
      <p>
        เรานัดรับสินค้าในพื้นที่{SITE.areas.map((a) => `อ.${a}`).join(' ')} และอำเภออื่นในจังหวัด
        ตามตารางงานจริงของทีมงาน โดยปกติไม่มีค่าบริการรับถึงที่แยกต่างหากในพื้นที่ให้บริการปกติ
      </p>
      <p>
        มีของหมวดอื่นอยากขายพร้อมกัน ดูรายละเอียด<a href={`/${sec.slug}/`}>{sec.kw} ขอนแก่น</a>
        หรือดูภาพรวมบริการ<a href="/">รับซื้อสินค้าไอทีในขอนแก่น</a>ได้จากหน้าหลัก
      </p>

      {clusterLinks.length > 0 && (
        <>
          <h4 class="h4-block">ลิงก์ในคลัสเตอร์เดียวกัน</h4>
          <div class="cluster-links">
            {clusterLinks.map((c) => (
              <a href={`/${c.slug}/`} class="cluster-link">
                <span>{c.icon}</span>
                <strong>{c.kw} ขอนแก่น</strong>
                <small>{c.short}</small>
              </a>
            ))}
          </div>
        </>
      )}

      <h4 class="h4-block">คำถามที่พบบ่อยเกี่ยวกับการขาย{cat.name}</h4>
      <div class="faq">
        {cat.faq.map((f) => (
          <details class="faq__item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>

      <h4 class="h4-block">หมวดที่เกี่ยวข้อง</h4>
      <div class="others">
        {others.slice(0, 6).map((c) => (
          <a href={`/${c.slug}/`} class="card other">
            <span>{c.icon}</span> {c.kw} ขอนแก่น
          </a>
        ))}
      </div>
    </div>

    <section class="section cta">
      <div class="container cta__in">
        <h4 class="cta__head">พร้อมขายแล้ว? ส่งรูปประเมิน{cat.name}ได้เลย</h4>
        <p>ถ่ายรูป ส่งไลน์ รอราคาเบื้องต้น — {SITE.hours} · {SITE.brandLine}</p>
        <div class="cta__btns">
          <a href={SITE.lineHref} class="btn btn--line" data-track-event="click_line">ทัก LINE {SITE.lineId}</a>
          <a href={SITE.phoneHref} class="btn btn--volt" data-track-event="click_phone">โทร {SITE.phone}</a>
        </div>
      </div>
    </section>
    </main>
  ) : (
    <main id="main-content" class="article detail-page">
      <section class="cat-hero">
        <div class="container">
          <nav class="crumb" aria-label="breadcrumb">
            <a href="/">หน้าแรก</a> <span>/</span> {detail.h1}
          </nav>
          <p class="eyebrow">{kind === 'brand' ? 'Brand / Demand Page' : kind === 'model' ? model.group : kind === 'condition' ? 'Condition Page' : 'พื้นที่ให้บริการ'}</p>
          <h1>{detail.h1}</h1>
          <p class="lede">{brand?.intro || model?.intent || condition?.priceImpact || localPage?.note}</p>
          <p class="lede lede--soft">{SITE.serviceModel}</p>
          <div class="cta-row">
            <a href={SITE.lineHref} class="btn btn--line" data-track-event="click_line">ส่งรูปประเมินฟรี LINE {SITE.lineId}</a>
            <a href={SITE.phoneHref} class="btn btn--ghost" data-track-event="click_phone">โทร {SITE.phone}</a>
          </div>
        </div>
      </section>

      <div class="container article__body">
        {brand && (
          <>
            <h2>ดีมานด์ของ {brand.brand} ในตลาดมือสองขอนแก่น</h2>
            <p>{brand.demand}</p>
            <h2>ซีรีส์ของ {brand.brand} ที่รับประเมินบ่อย</h2>
            <div class="chip-grid">{brand.acceptedModels.map((item) => <span>{item}</span>)}</div>
            <h2>สัญญาณที่ทำให้ราคา {brand.brand} สูงหรือต่ำ</h2>
            <ul>{brand.priceSignals.map((item) => <li>{item}</li>)}</ul>
            <h2>ข้อมูลเฉพาะที่ควรส่งมาก่อนประเมิน</h2>
            <ul>{brand.inspection.map((item) => <li>{item}</li>)}</ul>
            <div class="case-study"><strong>หมายเหตุเฉพาะแบรนด์:</strong> {brand.caution}</div>
          </>
        )}

        {model && (
          <>
            <h2>ข้อมูลเฉพาะของหน้านี้</h2>
            <ul>{model.specificData.map((item) => <li>{item}</li>)}</ul>
            <h2>ปัจจัยที่มีผลกับราคา</h2>
            <div class="chip-grid">{model.priceSignals.map((item) => <span>{item}</span>)}</div>
            <h2>ควรเตรียมอะไรส่งมาก่อนประเมิน</h2>
            <ul>{model.prepare.map((item) => <li>{item}</li>)}</ul>
          </>
        )}

        {condition && (
          <>
            <h2>หมวดสินค้าที่มักเจอสภาพนี้</h2>
            <p>{condition.priceImpact}</p>
            <h2>ควรถ่ายรูปอะไรส่งให้ทีมประเมิน</h2>
            <ul>
              <li>ภาพรวมรอบตัวเครื่องและอุปกรณ์ที่มี</li>
              <li>ภาพตำหนิระยะใกล้ให้เห็นชัด ไม่ใช้ฟิลเตอร์</li>
              <li>หน้าข้อมูลรุ่น ความจุ serial หรือสเปกเครื่อง</li>
              <li>วิดีโอสั้นถ้าอาการต้องเห็นตอนเปิดเครื่องหรือใช้งาน</li>
            </ul>
          </>
        )}

        {localPage && (
          <>
            <h2>รับซื้อสินค้าไอทีในโซน{localPage.area}อะไรบ้าง</h2>
            <p>
              {localPage.note}
              สินค้าที่มี demand ในพื้นที่นี้ ได้แก่ {localPage.demand.join(' · ')}
              หากอยู่ใกล้เคียงสามารถส่งพิกัดคร่าว ๆ ทาง LINE เพื่อจัดรอบได้
            </p>
            <div class="local-specific">
              <section>
                <h3>รูปแบบการนัดรับเฉพาะพื้นที่</h3>
                <p>{localPage.meetingStyle}</p>
              </section>
              <section>
                <h3>ช่วงให้บริการโดยไม่รับประกันเกินจริง</h3>
                <p>{localPage.serviceWindow}</p>
              </section>
            </div>
            <h2>จุดนัดที่ใช้จริงในโซน{localPage.area}</h2>
            <ul>{localPage.landmarks.map((item) => <li>{item}</li>)}</ul>
            {/* 
            <div class="local-photo">
              <div class="local-photo__mark" aria-hidden="true">แนวทางรูปจริง</div>
              <div>
                <h3>{localPage.photo.alt}</h3>
                <p>{localPage.photo.brief}</p>
              </div>
            </div>
            */}
            <h2>เคสรับซื้อจริงในพื้นที่{localPage.area}</h2>
            <div class="case-study">
              <p class="case-study__meta">{localPage.caseStudy.date} · {localPage.area}</p>
              <h3>{localPage.caseStudy.title}</h3>
              <p>{localPage.caseStudy.detail}</p>
            </div>
            <h2>คำถามที่พบจากลูกค้าในพื้นที่{localPage.area}</h2>
            <div class="faq">
              {localPage.faq.map((f) => (
                <details class="faq__item">
                  <summary>{f.q}</summary>
                  <p>{f.a}</p>
                </details>
              ))}
            </div>
            <h2>ข้อมูลติดต่อ NAP ที่ต้องตรงกัน</h2>
            <table>
              <tbody>
                <tr><th>ชื่อธุรกิจ</th><td>{LOCAL_NAP.name}</td></tr>
                <tr><th>พื้นที่บริการ</th><td>{LOCAL_NAP.serviceArea}</td></tr>
                <tr><th>โทร</th><td>{LOCAL_NAP.phone}</td></tr>
                <tr><th>LINE</th><td>{LOCAL_NAP.line}</td></tr>
                <tr><th>เวลา</th><td>{LOCAL_NAP.hours}</td></tr>
              </tbody>
            </table>
          </>
        )}

        {(detailPrimary || detailCategories.length > 0 || relatedBrands.length > 0 || relatedModels.length > 0) && (
          <>
            <h2>ลิงก์ต่อในคลัสเตอร์เดียวกัน</h2>
            <div class="cluster-links">
              {detailPrimary && (
                <a href={`/${detailPrimary.slug}/`} class="cluster-link">
                  <span>{detailPrimary.icon}</span>
                  <strong>{detailPrimary.kw} ขอนแก่น</strong>
                  <small>{detailPrimary.short}</small>
                </a>
              )}
              {detailCategories.map((c) => (
                <a href={`/${c.slug}/`} class="cluster-link">
                  <span>{c.icon}</span>
                  <strong>{c.kw} ขอนแก่น</strong>
                  <small>{c.short}</small>
                </a>
              ))}
              {relatedBrands.map((item) => (
                <a href={`/${item.path}/`} class="cluster-link">
                  <span>🏷</span>
                  <strong>{item.h1}</strong>
                  <small>{item.demand}</small>
                </a>
              ))}
              {relatedModels.map((item) => (
                <a href={`/${item.path}/`} class="cluster-link">
                  <span>▣</span>
                  <strong>{item.h1}</strong>
                  <small>{item.intent}</small>
                </a>
              ))}
            </div>
          </>
        )}

        <h2>ขั้นตอนส่งประเมินราคา</h2>
        <p>
          ถ่ายรูปตามรายการด้านบนแล้วส่งเข้า LINE {SITE.lineId}
          ทีมงานจะประเมินจากข้อมูลเฉพาะของรุ่น พื้นที่ และสภาพจริง ไม่ใช้ราคากลางแบบเปลี่ยนชื่อหน้าใน template เดียว
        </p>
      </div>
    </main>
  )}
</Base>

<style>
  .cat-hero { padding-block: 48px; }
  .cat-hero h1 {
    overflow-wrap: anywhere;
    word-break: break-word;
  }
  .lede, .article__body p, .article__body li {
    overflow-wrap: anywhere;
  }
  @media (max-width: 480px) {
    .cat-hero h1 {
      font-size: 1.6rem;
    }
    .lede {
      font-size: 0.95rem;
    }
  }
  .cat-hero__icon { font-size: 2.4rem; margin-bottom: 8px; }
  .lede { font-size: 1.05rem; color: var(--ink-soft); margin-bottom: 14px; max-width: 68ch; }
  .lede--soft { font-size: 0.98rem; color: var(--muted, #5b6577); }
  .cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin-top: 22px; }
  .crumb { font-size: 0.88rem; color: var(--ink-soft); margin-bottom: 18px; }
  .crumb a { color: var(--ink-soft); }
  .article__body { padding-block: 28px 56px; max-width: 760px; }
  .article__body h2 { margin-top: 36px; margin-bottom: 12px; }
  .article__body h3 { margin-top: 22px; margin-bottom: 8px; }
  .price-box { margin: 18px 0 22px; border: 1px solid var(--line); border-radius: 8px; overflow: hidden; background: #fff; }
  .price-box__head { padding: 16px 18px; background: var(--mist); }
  .price-box__head h3 { margin: 0 0 4px; font-size: 1.08rem; }
