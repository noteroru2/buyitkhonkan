---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site.js';

const title = `เงื่อนไขการรับซื้อ | ${SITE.name}`;
const description = `เงื่อนไขประเมินราคา เอกสาร และการรับซื้อสินค้าไอทีของ ${SITE.name} โดย ${SITE.company}`;
---

<Base title={title} description={description}>
  <main id="main-content" class="legal">
    <div class="container legal__in">
      <nav class="crumb" aria-label="breadcrumb">
        <a href="/">หน้าแรก</a> <span>/</span> เงื่อนไขการรับซื้อ
      </nav>
      <h1>เงื่อนไขการประเมินราคาและการรับซื้อ</h1>
      <p class="lede">อัปเดตล่าสุด: 11 กรกฎาคม 2026 · {SITE.brandLine}</p>

      <h2>1. ราคาอ้างอิงเบื้องต้น</h2>
      <p>
        ราคาที่แจ้งผ่าน LINE หรือโทรศัพท์เป็นราคาอ้างอิงเบื้องต้นตามข้อมูลที่ผู้ขายส่งมา
        ไม่ใช่ราคาสุดท้ายจนกว่าจะตรวจสภาพจริงหน้างาน
        ราคาอาจเปลี่ยนตามรุ่นย่อย สภาพ แบตเตอรี่ อุปกรณ์ ตำหนิ และราคาตลาด ณ วันที่ตรวจสอบ
      </p>

      <h2>2. กรรมสิทธิ์และเอกสาร</h2>
      <ul>
        <li>ผู้ขายต้องเป็นเจ้าของสินค้าหรือมีสิทธิ์ในการจำหน่ายโดยชอบ</li>
        <li>ต้องแสดงบัตรประชาชนหรือเอกสารยืนยันตัวตนตามที่ทีมงานร้องขอ</li>
        <li>สินค้าที่ติดผ่อน ติดสัญญา หรือติดบัญชีผู้ผลิต ต้องปลดภาระก่อนรับซื้อ</li>
        <li>เราไม่รับซื้อสินค้าที่สงสัยว่าได้มาโดยไม่ชอบด้วยกฎหมาย</li>
      </ul>

      <h2>3. ข้อมูลส่วนตัวในอุปกรณ์</h2>
      <p>
        ผู้ขายควรสำรองข้อมูลและออกจากบัญชี (เช่น iCloud, Google, Find My)
        ก่อนวันนัดรับ ทีมงานอาจช่วยแนะนำขั้นตอน แต่ความรับผิดชอบหลักอยู่ที่ผู้ขาย
      </p>

      <h2>4. การชำระเงิน</h2>
      <p>
        จ่ายเงินสดหรือโอนเข้าบัญชีต่อหน้าผู้ขายหลังตรวจสภาพและตกลงขายแล้ว
        ไม่มีการรับสินค้าไปก่อนแล้วโอนทีหลัง
      </p>

      <h2>5. การนัดรับ</h2>
      <p>
        เป็นบริการนัดรับถึงที่หรือนัดจุดกลาง ไม่มีหน้าร้านให้เดินเข้าใช้บริการ
        พื้นที่และเวลานัดรับขึ้นอยู่กับตารางงานของทีมงานในแต่ละวัน
      </p>

      <p>
        สอบถามเพิ่มเติมที่<a href="/ติดต่อเรา/">หน้าติดต่อเรา</a>
        หรืออ่าน<a href="/นโยบายความเป็นส่วนตัว/">นโยบายความเป็นส่วนตัว</a>
      </p>
    </div>
  </main>
</Base>

<style>
  .legal__in { max-width: 720px; padding-block: 48px 72px; }
  .crumb { font-size: 0.88rem; color: var(--ink-soft); margin-bottom: 18px; }
  .lede { font-size: 1.05rem; color: var(--ink-soft); margin: 14px 0 28px; }
  .legal h2 { margin: 28px 0 10px; }
  .legal p, .legal li { color: #2b3547; margin-bottom: 10px; }
  .legal ul { margin: 0 0 14px 22px; }
</style>
