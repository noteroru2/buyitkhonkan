---
import Base from '../layouts/Base.astro';
import Ticker from '../components/Ticker.astro';
import { SITE, CATEGORIES } from '../data/categories.js';

const title = 'รับซื้อสินค้าไอที ขอนแก่น จ่ายสด นัดรับถึงที่ | WINNER IT';
const description =
  'WINNER IT โดยบริษัท อำพล เทรดดิ้ง จำกัด บริการประเมินและนัดรับซื้อสินค้าไอทีในจังหวัดขอนแก่น โน้ตบุ๊ค MacBook iPhone คอมพิวเตอร์ การ์ดจอ เครื่องเกม กล้อง ประเมินผ่าน LINE @buyhub จ่ายเงินสดหรือโอนหน้างาน';

const faqs = [
  {
    q: 'ประเมินราคายังไง ต้องเอาของมาให้ดูก่อนไหม?',
    a: 'ไม่ต้องครับ ถ่ายรูปสินค้า แจ้งรุ่นและสภาพ ส่งเข้าไลน์ @buyhub หลังได้รับข้อมูลครบ ทีมงานจะแจ้งราคาเบื้องต้นตามลำดับคิวในเวลาทำการ ถูกใจราคาค่อยนัดวันรับของ',
  },
  {
    q: 'มีหน้าร้านให้เดินเข้าไปไหม?',
    a: 'ตอนนี้ยังไม่มีหน้าร้านในขอนแก่นให้เดินเข้าใช้บริการ เป็นบริการนัดรับถึงที่หรือนัดจุดกลางโดยทีมงานบริษัท อำพล เทรดดิ้ง จำกัด',
  },
  {
    q: 'จ่ายเงินยังไง ได้เงินเมื่อไหร่?',
    a: 'จ่ายเงินสดหรือโอนเข้าบัญชีต่อหน้าผู้ขายหลังตรวจสภาพเสร็จ ไม่มีมัดจำ ไม่มีรับของไปก่อนแล้วโอนตามหลัง',
  },
  {
    q: 'รับถึงที่ไหม มีค่าบริการหรือเปล่า?',
    a: 'นัดรับถึงที่ได้ตามตารางงานของทีมงาน โดยปกติไม่มีค่าบริการรับถึงที่แยกต่างหากในพื้นที่ให้บริการปกติ เขตตัวเมืองและต่างอำเภอนัดตามคิวในแต่ละวัน',
  },
  {
    q: 'ของมีตำหนิ จอแตก เปิดไม่ติด รับไหม?',
    a: 'รับประเมินตามสภาพจริงครับ เครื่องเสียยังอาจมีมูลค่าอะไหล่ แจ้งตำหนิมาตรง ๆ ตั้งแต่แรกจะได้ตัวเลขที่ใกล้เคียงสภาพจริงมากขึ้น',
  },
  {
    q: 'ต้องเตรียมเอกสารอะไรบ้าง?',
    a: 'บัตรประชาชนของผู้ขาย ถ้ามีกล่องหรือใบเสร็จช่วยประกอบการประเมินได้ ฝั่งเราออกหลักฐานการซื้อขายให้เก็บไว้ทุกดีล',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const steps = [
  { n: '1', t: 'ส่งรูปทางไลน์', d: 'ถ่ายรูปสินค้าให้เห็นสภาพรอบเครื่อง แจ้งรุ่นและตำหนิถ้ามี ส่งเข้าไลน์ @buyhub ในเวลาทำการ' },
  { n: '2', t: 'รับราคาเบื้องต้น', d: 'ประเมินตามรุ่น สเปก สภาพ อุปกรณ์ และราคาตลาด ณ วันที่ตรวจสอบ ตัวเลขไม่ผูกมัด จนกว่าจะตรวจจริง' },
  { n: '3', t: 'นัดรับ จ่ายหน้างาน', d: 'นัดจุดรับหรือให้ทีมงานไปรับถึงที่ตามตารางงาน ตรวจของต่อหน้า แล้วรับเงินสดหรือโอนทันที' },
];

const moneyCategories = CATEGORIES.filter((c) => !['gadget', 'smartwatch', 'appliance'].includes(c.slug));
---

<Base title={title} description={description} jsonLd={[faqJsonLd]} includeOrganization={true}>
  <main id="main-content">
    <section class="hero">
      <div class="container hero__in">
        <div class="hero__copy">
          <p class="eyebrow">{SITE.brandLine}</p>
          <h1>
            รับซื้อสินค้าไอที ขอนแก่น<br />
            <span class="hero__hl">นัดรับถึงที่ จ่ายสดหน้างาน</span>
          </h1>
          <p class="hero__sub">
            {SITE.serviceModel}
            โน้ตบุ๊ค มือถือ คอมพิวเตอร์ การ์ดจอ เครื่องเกม กล้อง — ประเมินตามสภาพจริงผ่านไลน์
            ไม่มีข้อผูกมัดก่อนตกลงขาย
          </p>
          <div class="hero__cta">
            <a href={SITE.lineHref} class="btn btn--line" data-track-event="click_line">ประเมินราคาผ่าน LINE {SITE.lineId}</a>
            <a href={SITE.phoneHref} class="btn btn--ghost" data-track-event="click_phone">โทร {SITE.phone}</a>
          </div>
          <ul class="hero__points">
            <li>ราคาอิงตลาดจริง</li>
            <li>จ่ายสด / โอนหน้างาน</li>
            <li>มีตำหนิก็ประเมินได้</li>
          </ul>
        </div>
        <div class="hero__panel" aria-hidden="true">
          <p class="hero__panel-label">ตัวอย่างที่รับซื้อวันนี้</p>
          {moneyCategories.slice(0, 4).map((c) => (
            <div class="hero__row">
              <span class="hero__row-icon">{c.icon}</span>
              <span class="hero__row-name">{c.name}</span>
              <span class="hero__row-tag">รับซื้อ ▲</span>
            </div>
          ))}
        </div>
      </div>
    </section>

    <Ticker />

    <!-- ===== H2 #1 (keyword) : หมวดสินค้า ===== -->
    <section class="section" id="categories">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">สินค้าที่รับซื้อ</p>
          <h2>รับซื้อสินค้าไอทีทุกประเภท ครอบคลุม 12 หมวดสินค้าหลัก</h2>
          <p>
            หมวดสินค้าหลักทั้ง 12 หมวดถูกแยกตามการใช้งานอย่างชัดเจน โดยเฉพาะเครื่องเกมที่แยกออกจากแกดเจ็ต
            และอุปกรณ์สำนักงานที่ย้ายไปเป็นหน้ารองของงานเหมา กดเข้าไปดูรุ่น ตารางราคา และเคสตัวอย่างได้เลย
          </p>
        </div>
        <div class="cat-grid">
          {moneyCategories.map((c) => (
            <a href={`/${c.slug}/`} class="card cat">
              <span class="cat__icon">{c.icon}</span>
              <h3>{c.kw} ขอนแก่น</h3>
              <p>{c.short}</p>
              <span class="cat__more">ดูรายละเอียด →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== H2 #2 (keyword) : จุดแข็ง + H3 ===== -->
    <section class="section section--mist">
      <div class="container prose">
        <h2>ทำไมคนขอนแก่นเลือกขายสินค้าไอทีกับ WINNER IT</h2>
        <p>
          ตลาดรับซื้อมือสองมักมีปัญหา ราคาคุยไว้แล้วเปลี่ยนตอนเจอหน้า หรือรับของไปก่อนแล้วให้รอโอน
          เราออกแบบบริการให้ตรวจสอบได้ และสื่อสารเงื่อนไขก่อนนัดรับทุกครั้ง
        </p>
        <h3>ราคาเบื้องต้นอิงข้อมูลที่แจ้ง — จ่ายตามสภาพจริงหน้างาน</h3>
        <p>
          ตัวเลขในไลน์เป็นราคาอ้างอิงเบื้องต้นตามข้อมูลที่ผู้ขายส่งมา
          หากสภาพตรงตามที่แจ้ง จะจ่ายตามที่ตกลง หากต่างจากข้อมูล ทีมงานจะอธิบายส่วนต่างก่อนตัดสินใจขาย
        </p>
        <h3>บริษัทจดทะเบียน ตรวจสอบได้</h3>
        <p>
          การซื้อขายดำเนินการในนามบริษัท อำพล เทรดดิ้ง จำกัด มีหลักฐานการรับซื้อออกให้ผู้ขายเก็บไว้
          ฝั่งองค์กรที่ต้องจำหน่ายทรัพย์สินตามระเบียบใช้เอกสารประกอบบัญชีได้
        </p>
        <h3>บริการนัดรับถึงที่ — ไม่มีหน้าร้านให้เดินเข้า</h3>
        <p>
          ขณะนี้ยังไม่มีหน้าร้านในขอนแก่นให้เดินเข้าใช้บริการ เป็นบริการนัดรับถึงที่หรือนัดจุดกลาง
          ของชิ้นใหญ่หรือยกล็อต ทีมงานจัดรอบรับตามตารางงาน โดยปกติไม่มีค่าบริการรับถึงที่แยกในพื้นที่ให้บริการปกติ
        </p>
      </div>
    </section>

    <!-- ===== H2 #3 : ขั้นตอน ===== -->
    <section class="section" id="steps">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">ขั้นตอนการขาย</p>
          <h2>ขายของไอทีกับเรา 3 ขั้นตอน</h2>
          <p>
            ส่งข้อมูลประเมินก่อน ตกลงราคาเบื้องต้น แล้วนัดรับตามตารางงานของทีมงาน
            ระยะเวลาขึ้นอยู่กับความครบของข้อมูลและคิวในแต่ละวัน
          </p>
        </div>
        <ol class="steps">
          {steps.map((s) => (
            <li class="card step">
              <span class="step__n">{s.n}</span>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </li>
          ))}
        </ol>
    </section>

    <!-- ===== H2 #5 : ขั้นตอนการให้บริการโดยสรุป ===== -->
    <section class="section section--trust" id="trust-gallery">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">ขั้นตอนการดำเนินงาน</p>
          <h2>ขั้นตอนการให้บริการโดยสรุป</h2>
          <p>
            ข้อมูลแสดงรายละเอียดขั้นตอนการดำเนินงานในการรับซื้อสินค้าไอทีในจังหวัดขอนแก่น ตั้งแต่การนัดรับ การตรวจเช็กสภาพเครื่อง ตลอดจนการชำระเงิน
          </p>
          <p class="trust-disclaimer">
            * ภาพประกอบเพื่ออธิบายขั้นตอนการให้บริการ ไม่ใช่ภาพลูกค้า สถานที่ หรือธุรกรรมจริง
          </p>
        </div>
        <div class="trust-grid">
          <div class="trust-card">
            <div class="trust-img-wrapper">
              <img src="/images/trust-inspection.png" alt="ภาพประกอบการตรวจสอบสภาพโน้ตบุ๊คและอุปกรณ์โดยละเอียดเพื่อประเมินราคา" width="400" height="300" loading="lazy" />
            </div>
            <h3>การตรวจเช็กและวิเคราะห์สภาพเครื่อง</h3>
            <p>ตรวจสินค้าต่อหน้าผู้ขาย อธิบายจุดประเมินและสภาพอะไหล่ตามจริง ไม่มีการแอบอ้างตำหนิ</p>
          </div>
          <div class="trust-card">
            <div class="trust-img-wrapper">
              <img src="/images/trust-inventory.png" alt="ภาพประกอบตัวอย่างประเภทโน้ตบุ๊คและสินค้าไอทีเพื่อชี้แจงกลุ่มอุปกรณ์ที่รับซื้อ" width="400" height="300" loading="lazy" />
            </div>
            <h3>ตัวอย่างประเภทสินค้าที่รับประเมิน</h3>
            <p>ภาพประกอบกลุ่มโน้ตบุ๊ก มือถือ และอุปกรณ์ไอทีที่สามารถส่งข้อมูลมาประเมินได้</p>
          </div>
          <div class="trust-card">
            <div class="trust-img-wrapper trust-icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="trust-svg-icon" aria-label="ภาพประกอบสัญลักษณ์ขั้นตอนการรับชำระเงิน">
                <rect x="2" y="5" width="20" height="14" rx="2" />
                <line x1="2" y1="10" x2="22" y2="10" />
                <line x1="6" y1="15" x2="6.01" y2="15" />
                <line x1="10" y1="15" x2="10.01" y2="15" />
              </svg>
            </div>
            <h3>ตัวอย่างขั้นตอนตรวจสอบและชำระเงิน</h3>
            <p>หลังตรวจสินค้าและตกลงราคากันแล้ว ลูกค้าสามารถเลือกรับเงินสดหรือเงินโอนได้</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== H2 #4 (keyword) : หลักการตีราคา + external + บทความ ===== -->
    <section class="section section--mist">
      <div class="container prose">
        <h2>ราคารับซื้อสินค้าไอทีมือสอง เราประเมินจากอะไร</h2>
        <p>
          ทุกหมวดใช้หลักเดียวกันคืออิงราคาตลาดจริง ณ วันขาย ประกอบกับรุ่น อายุการใช้งาน
          สภาพภายนอก ความสมบูรณ์ของฟังก์ชัน และความครบของอุปกรณ์แถม ไม่มีสูตรกดราคาเหมารวม
          ของที่มีตำหนิจะถูกหักตามค่าซ่อมจริงเป็นรายการ ไม่ใช่ตัดทิ้งครึ่งราคาแบบไร้ที่มา
          ตัวอย่างการอัปเดตราคารายเดือนดูได้จากบทความ
          <a href="/blog/macbook-resale-price/">ราคารับซื้อ MacBook มือสองทุกรุ่น</a>
          และเทคนิคเตรียมเครื่องอ่านได้ที่
          <a href="/blog/erase-iphone-before-selling/">วิธีลบข้อมูล iPhone ก่อนขาย</a>
        </p>
        <p>
          ก่อนตัดสินใจขายกับใครก็ตาม แนะนำให้เช็กตัวตนของผู้รับซื้อเสมอ สถานะนิติบุคคลของเราตรวจสอบได้ที่
          <a href="https://www.dbd.go.th" target="_blank" rel="noopener">กรมพัฒนาธุรกิจการค้า</a>
          — ความโปร่งใสคือสิ่งที่ผู้ขายทุกคนควรได้รับก่อนส่งมอบของมีค่า
        </p>
      </div>
    </section>

    <!-- ===== H2 #5 (keyword) : พื้นที่บริการ ===== -->
    <section class="section">
      <div class="container prose">
        <h2>พื้นที่ให้บริการรับซื้อสินค้าไอทีในจังหวัดขอนแก่น</h2>
        <p>
          {SITE.serviceModel}
          พื้นที่นัดรับครอบคลุม{SITE.areas.map((a) => `อ.${a}`).join(' ')} และอำเภออื่นในจังหวัดตามตารางงานจริง
          เปิดให้บริการ{SITE.hours}
          ช่องทางหลักคือไลน์ {SITE.lineId} และโทร {SITE.phone} (อีเมล {SITE.email})
        </p>

        <!-- FAQ ใช้ H4 ตาม audit -->
        <h4 class="h4-block">คำถามที่พบบ่อย</h4>
        <div class="faq">
          {faqs.map((f) => (
            <details class="faq__item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container prose">
        <h2>หน้าช่วยตัดสินใจก่อนขาย</h2>
        <p>
          ถ้าสินค้ามีตำหนิ ดูหน้าสรุป<a href="/สภาพสินค้าที่ขายได้/">สภาพสินค้าที่ขายได้</a>
          หรือเลือกดูหน้าเฉพาะที่มีข้อมูลจริง เช่น
          <a href="/รับซื้อ-dell-ขอนแก่น/">Dell</a>, <a href="/รับซื้อ-hp-ขอนแก่น/">HP</a>,
          <a href="/รับซื้อ-asus-ขอนแก่น/">ASUS</a>, <a href="/รับซื้อ-lenovo-ขอนแก่น/">Lenovo</a>,
          <a href="/รับซื้อ-macbook-air-ขอนแก่น/">MacBook Air</a> และ <a href="/รับซื้อคอมเกมมิ่ง-ขอนแก่น/">คอมเกมมิ่ง</a>
          เพื่อเตรียมข้อมูลก่อนส่งประเมิน
        </p>
      </div>
    </section>

    <!-- ===== CTA ปิดท้าย ===== -->
    <section class="section cta">
      <div class="container cta__in">
        <h4 class="cta__head">มีของไอทีอยากขาย? ส่งรูปประเมินได้เลย</h4>
