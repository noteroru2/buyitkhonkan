---
import Base from '../layouts/Base.astro';
import Ticker from '../components/Ticker.astro';
import { SITE, CATEGORIES } from '../data/categories.js';
import ProductCategoryImage from '../components/media/ProductCategoryImage.astro';
import { PRODUCT_IMAGES } from '../data/productImages';
import ResponsiveImage from '../components/media/ResponsiveImage.astro';
import processInspectionImage from '../assets/images/illustrations/ai/process/notebook-exterior-check-ai.webp';

const title = 'รับซื้อสินค้าไอที ขอนแก่น จ่ายสด นัดรับถึงที่ | WINNER IT';
const description =
  'รับซื้อสินค้าไอทีในขอนแก่น โน้ตบุ๊ค MacBook iPhone คอมพิวเตอร์ การ์ดจอ เครื่องเกมและกล้อง ส่งรูปทาง LINE เพื่อประเมินเบื้องต้นและนัดรับตามคิว';

const faqs = [
  {
    q: 'ประเมินราคายังไง ต้องเอาของมาให้ดูก่อนไหม?',
    a: 'ไม่ต้องครับ ถ่ายรูปสินค้า แจ้งรุ่นและสภาพ ส่งเข้าไลน์ @buyhub หลังได้รับข้อมูลครบ ทีมงานจะแจ้งราคาเบื้องต้นตามลำดับคิวในเวลาทำการ ถูกใจราคาค่อยนัดวันรับของ',
  },
  {
    q: 'มีหน้าร้านให้เดินเข้าไปไหม?',
    a: 'ตอนนี้ยังไม่มีหน้าร้านในขอนแก่นให้เดินเข้าใช้บริการ เป็นบริการนัดรับถึงที่หรือนัดจุดกลางโดยทีมงานบริษัท อำพล เทรดดิ้ง จำกัด',
  },
  {
    q: 'จ่ายเงินยังไง ได้เงินเมื่อไหร่?',
    a: 'จ่ายเงินสดหรือโอนเข้าบัญชีต่อหน้าผู้ขายหลังตรวจสภาพเสร็จ ไม่มีมัดจำ ไม่มีรับของไปก่อนแล้วโอนตามหลัง',
  },
  {
    q: 'รับถึงที่ไหม มีค่าบริการหรือเปล่า?',
    a: 'นัดรับถึงที่ได้ตามตารางงานของทีมงาน โดยปกติไม่มีค่าบริการรับถึงที่แยกต่างหากในพื้นที่ให้บริการปกติ เขตตัวเมืองและต่างอำเภอนัดตามคิวในแต่ละวัน',
  },
  {
    q: 'ของมีตำหนิ จอแตก เปิดไม่ติด รับไหม?',
    a: 'รับประเมินตามสภาพจริงครับ เครื่องเสียยังอาจมีมูลค่าอะไหล่ แจ้งตำหนิมาตรง ๆ ตั้งแต่แรกจะได้ตัวเลขที่ใกล้เคียงสภาพจริงมากขึ้น',
  },
  {
    q: 'ต้องเตรียมเอกสารอะไรบ้าง?',
    a: 'บัตรประชาชนของผู้ขาย ถ้ามีกล่องหรือใบเสร็จช่วยประกอบการประเมินได้ ฝั่งเราออกหลักฐานการซื้อขายให้เก็บไว้ทุกดีล',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const steps = [
  { n: '1', t: 'ส่งข้อมูลสินค้า', d: 'ถ่ายรูปสินค้าให้เห็นสภาพรอบเครื่อง แจ้งรุ่น สเปก อุปกรณ์ และตำหนิถ้ามี ส่งเข้าไลน์ @buyhub' },
  { n: '2', t: 'รับการประเมินเบื้องต้น', d: 'ทีมงานประเมินจากข้อมูลที่ได้รับ รุ่น สภาพ อุปกรณ์ และราคาตลาด ณ วันที่ตรวจสอบ' },
  { n: '3', t: 'นัดตรวจและตกลงราคา', d: 'ตรวจของต่อหน้า อธิบายส่วนต่างหากมี แล้วชำระเงินสดหรือโอนเมื่อผู้ขายยืนยันราคา' },
];

const benefits = [
  { icon: 'ข้อมูล', t: 'ประเมินจากข้อมูลสินค้า', d: 'ดูรุ่น สเปก สภาพจริง อุปกรณ์ และความต้องการของตลาด ไม่ใช้ราคาเหมารวมทุกเครื่อง' },
  { icon: 'ราคา', t: 'อธิบายปัจจัยที่มีผลต่อราคา', d: 'หากราคาต่างจากที่คาด ทีมงานแจ้งเหตุผลจากสภาพ เครื่อง อะไหล่ หรืออุปกรณ์ที่ขาดให้ทราบก่อน' },
  { icon: 'คิว', t: 'นัดรับตามพื้นที่และคิวงาน', d: 'บริการเป็นรอบนัดรับในจังหวัดขอนแก่นตามตารางงานจริง ไม่มีการอ้างว่ามีหน้าร้านให้ walk-in' },
  { icon: 'จ่าย', t: 'เลือกรับเงินสดหรือเงินโอน', d: 'ชำระหลังตรวจสอบและตกลงราคาแล้วต่อหน้าผู้ขาย พร้อมหลักฐานการซื้อขายสำหรับเก็บไว้' },
];

const priceFactors = [
  'รุ่น ปีที่วางจำหน่าย และ demand ของตลาดมือสอง',
  'สเปกสำคัญ เช่น CPU, RAM, ความจุ, การ์ดจอ หรือสุขภาพแบตเตอรี่',
  'สภาพภายนอก จอ พอร์ต ปุ่ม กล้อง และการทำงานของฟังก์ชันหลัก',
  'อุปกรณ์ กล่อง ใบเสร็จ ประกัน หรือบัญชีที่ต้องปลดล็อกก่อนขาย',
];

const resources = [
  { label: 'คู่มือราคา', title: 'ราคารับซื้อ MacBook มือสอง', desc: 'ดูปัจจัยที่ทำให้ราคา MacBook ขึ้นลงก่อนส่งประเมิน', href: '/บทความ/ราคารับซื้อ-macbook-มือสอง/' },
  { label: 'เตรียมเครื่อง', title: 'วิธีลบข้อมูล iPhone ก่อนขาย', desc: 'เช็กขั้นตอนสำคัญเพื่อปกป้องข้อมูลส่วนตัวก่อนส่งมอบ', href: '/บทความ/วิธีลบข้อมูล-iphone-ก่อนขาย/' },
  { label: 'สภาพสินค้า', title: 'สภาพสินค้าที่ขายได้', desc: 'ดูตัวอย่างตำหนิและอาการเสียที่ยังสามารถส่งประเมินได้', href: '/สภาพสินค้าที่ขายได้/' },
  { label: 'พื้นที่บริการ', title: 'พื้นที่ให้บริการในขอนแก่น', desc: 'ตรวจโซนนัดรับและข้อมูลบริการแบบ service-area', href: '/พื้นที่ให้บริการ/' },
];

const moneyCategories = CATEGORIES.filter((c) => !['gadget', 'smartwatch', 'appliance'].includes(c.slug));
---

<Base title={title} description={description} jsonLd={[faqJsonLd]} includeOrganization={true}>
  <main id="main-content">
    <section class="hero">
      <div class="container hero__in">
        <div class="hero__copy">
          <p class="eyebrow">{SITE.brandLine}</p>
          <h1>
            รับซื้อสินค้าไอที ขอนแก่น
            <span class="hero__hl">นัดรับถึงที่ จ่ายสดหน้างาน</span>
          </h1>
          <p class="hero__sub">
            {SITE.serviceModel}
            โน้ตบุ๊ค มือถือ คอมพิวเตอร์ การ์ดจอ เครื่องเกม กล้อง — ประเมินตามสภาพจริงผ่านไลน์
            ไม่มีข้อผูกมัดก่อนตกลงขาย
          </p>
          <div class="hero__cta">
            <a href={SITE.lineHref} class="btn btn--line" data-track-event="click_line">ประเมินราคาผ่าน LINE {SITE.lineId}</a>
            <a href={SITE.phoneHref} class="btn btn--ghost" data-track-event="click_phone">โทร {SITE.phone}</a>
          </div>
          <ul class="hero__points">
            <li>ราคาอิงตลาดจริง</li>
            <li>จ่ายสด / โอนหน้างาน</li>
            <li>มีตำหนิก็ประเมินได้</li>
          </ul>
        </div>
        <div class="hero__panel">
          <p class="hero__panel-label">บริการประเมินสินค้าไอที</p>
          <h2 class="hero__panel-title">ส่งข้อมูลครั้งเดียว ประเมินได้หลายหมวด</h2>
          <p class="hero__panel-copy">เหมาะกับเครื่องส่วนตัว เครื่องทำงาน หรือของหลายชิ้นที่ต้องการเคลียร์ออกอย่างเป็นระบบ</p>
          <div class="hero__rows">
            {moneyCategories.slice(0, 5).map((c) => (
              <a class="hero__row" href={`/${c.path || c.slug}/`}>
                <span class="hero__row-icon" aria-hidden="true">{c.icon}</span>
                <span class="hero__row-name">{c.name}</span>
                <span class="hero__row-tag">ดูหน้า</span>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <Ticker />

    <!-- ===== H2 #1 (keyword) : หมวดสินค้า ===== -->
    <section class="section" id="categories">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">สินค้าที่รับซื้อ</p>
          <h2>รับซื้อสินค้าไอทีทุกประเภท ครอบคลุม 12 หมวดสินค้าหลัก</h2>
          <p>
            หมวดสินค้าหลักทั้ง 12 หมวดถูกแยกตามการใช้งานอย่างชัดเจน โดยเฉพาะเครื่องเกมที่แยกออกจากแกดเจ็ต
            และอุปกรณ์สำนักงานที่ย้ายไปเป็นหน้ารองของงานเหมา กดเข้าไปดูรุ่น ตารางราคา และเคสตัวอย่างได้เลย
          </p>
        </div>
        <div class="cat-grid">
          {moneyCategories.map((c) => (
            <a href={`/${c.path || c.slug}/`} class="card cat">
              {PRODUCT_IMAGES[c.slug] && <ProductCategoryImage image={PRODUCT_IMAGES[c.slug]} slotId={`home-category-${c.slug}`} class="cat__image" />}
              <span class="cat__icon">{c.icon}</span>
              <h3>{c.kw} ขอนแก่น</h3>
              <p>{c.short}</p>
              <span class="cat__more">ดูรายละเอียด →</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section section--mist">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">ทำไมเลือกเรา</p>
          <h2>ทำไมคนขอนแก่นเลือกขายสินค้าไอทีกับ WINNER IT</h2>
          <p>
            ตลาดรับซื้อมือสองมักมีปัญหาราคาคุยไว้แล้วเปลี่ยนตอนเจอหน้า หรือรับของไปก่อนแล้วให้รอโอน
            เราจึงวางขั้นตอนให้ตรวจสอบได้และสื่อสารเงื่อนไขก่อนนัดรับทุกครั้ง
          </p>
        </div>
        <div class="benefit-grid">
          {benefits.map((item) => (
            <article class="card benefit-card">
              <span class="icon-badge">{item.icon}</span>
              <h3>{item.t}</h3>
              <p>{item.d}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== H2 #3 : ขั้นตอน ===== -->
    <section class="section" id="steps">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">ขั้นตอนการขาย</p>
          <h2>ขายของไอทีกับเรา 3 ขั้นตอน</h2>
          <p>
            ส่งข้อมูลประเมินก่อน ตกลงราคาเบื้องต้น แล้วนัดรับตามตารางงานของทีมงาน
            ระยะเวลาขึ้นอยู่กับความครบของข้อมูลและคิวในแต่ละวัน
          </p>
        </div>
        <ResponsiveImage
          src={processInspectionImage}
          alt="บุคคลใช้ไฟฉายตรวจสภาพภายนอกของโน้ตบุ๊กบนโต๊ะอุปกรณ์"
          caption="ภาพประกอบขั้นตอนการตรวจและจัดเตรียมอุปกรณ์"
          width={1200}
          height={900}
          widths={[480, 768, 960, 1200]}
          sizes="(max-width: 640px) calc(100vw - 40px), 720px"
          loading="lazy"
          fetchpriority="low"
          slotId="HOM-PROC-01"
          class="process-illustration"
        />
        <ol class="steps">
          {steps.map((s) => (
            <li class="card step">
              <span class="step__n">{s.n}</span>
              <h3>{s.t}</h3>
              <p>{s.d}</p>
            </li>
          ))}
        </ol>
      </div>
    </section>

    <!-- ===== H2 #5 : ขั้นตอนการให้บริการโดยสรุป ===== -->
    <section class="section section--trust" id="trust-gallery">
      <div class="container">
        <div class="section-head">
          <p class="eyebrow">ขั้นตอนการดำเนินงาน</p>
          <h2>ขั้นตอนการให้บริการโดยสรุป</h2>
          <p>
            ข้อมูลแสดงรายละเอียดขั้นตอนการดำเนินงานในการรับซื้อสินค้าไอทีในจังหวัดขอนแก่น ตั้งแต่การนัดรับ การตรวจเช็กสภาพเครื่อง ตลอดจนการชำระเงิน
          </p>
          <p class="trust-disclaimer">
            * ภาพประกอบเพื่ออธิบายขั้นตอนการให้บริการ ไม่ใช่ภาพลูกค้า สถานที่ หรือธุรกรรมจริง
          </p>
        </div>
        <div class="trust-grid">
          <div class="trust-card">
            <div class="trust-img-wrapper">
              <img src="/images/trust-inspection.png" alt="ภาพประกอบการตรวจสอบสภาพโน้ตบุ๊คและอุปกรณ์โดยละเอียดเพื่อประเมินราคา" width="400" height="300" loading="lazy" />
            </div>
            <h3>การตรวจเช็กและวิเคราะห์สภาพเครื่อง</h3>
            <p>ตรวจสินค้าต่อหน้าผู้ขาย อธิบายจุดประเมินและสภาพอะไหล่ตามจริง ไม่มีการแอบอ้างตำหนิ</p>
          </div>
          <div class="trust-card">
            <div class="trust-img-wrapper">
              <img src="/images/trust-inventory.png" alt="ภาพประกอบตัวอย่างประเภทโน้ตบุ๊คและสินค้าไอทีเพื่อชี้แจงกลุ่มอุปกรณ์ที่รับซื้อ" width="400" height="300" loading="lazy" />
            </div>
            <h3>ตัวอย่างประเภทสินค้าที่รับประเมิน</h3>
            <p>ภาพประกอบกลุ่มโน้ตบุ๊ก มือถือ และอุปกรณ์ไอทีที่สามารถส่งข้อมูลมาประเมินได้</p>
          </div>
          <div class="trust-card">
            <div class="trust-img-wrapper trust-icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="trust-svg-icon" aria-label="ภาพประกอบสัญลักษณ์ขั้นตอนการรับชำระเงิน">
                <rect x="2" y="5" width="20" height="14" rx="2" />
                <line x1="2" y1="10" x2="22" y2="10" />
                <line x1="6" y1="15" x2="6.01" y2="15" />
                <line x1="10" y1="15" x2="10.01" y2="15" />
              </svg>
            </div>
            <h3>ตัวอย่างขั้นตอนตรวจสอบและชำระเงิน</h3>
            <p>หลังตรวจสินค้าและตกลงราคากันแล้ว ลูกค้าสามารถเลือกรับเงินสดหรือเงินโอนได้</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== H2 #4 (keyword) : หลักการตีราคา + external + บทความ ===== -->
    <section class="section section--mist">
      <div class="container price-section">
        <div class="section-head">
          <p class="eyebrow">หลักการประเมินราคา</p>
          <h2>ราคารับซื้อสินค้าไอทีมือสอง เราประเมินจากอะไร</h2>
          <p>
            ราคาที่แจ้งผ่านไลน์เป็นราคาอ้างอิงเบื้องต้น ไม่ใช่ราคายืนยันจนกว่าจะตรวจสภาพจริง
            ทุกหมวดประเมินจากข้อมูลสินค้าและสภาพหน้างานเป็นหลัก
          </p>
        </div>
        <div class="price-panel">
          <div class="price-panel__summary">
            <span class="icon-badge">ราคา</span>
            <h3>ปัจจัยที่ทำให้ราคาขึ้นหรือลง</h3>
            <p>
              ของที่มีตำหนิจะประเมินตามค่าซ่อมหรือมูลค่าอะไหล่เป็นรายการ
              ไม่ใช้สูตรกดราคาเหมารวมแบบไม่มีที่มา
            </p>
          </div>
          <ul class="price-list">
            {priceFactors.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <p class="price-links">
          อ่านตัวอย่างราคาเพิ่มเติมได้ที่
