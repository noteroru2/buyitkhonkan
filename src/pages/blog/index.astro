    desc: 'คู่มือจัดการทรัพย์สินไอทีออฟฟิศ พร้อมกระบวนการรับซื้อยกล็อตที่ออกเอกสารครบสำหรับบริษัท',
    tag: 'Local',
  },
  {
    href: '/blog/kku-student-sell-notebook-ipad/',
    title: 'นักศึกษา มข. เรียนจบ ขายโน้ตบุ๊ค iPad ที่ไหนได้ราคาดีในขอนแก่น',
    desc: 'แนะนำนักศึกษาที่กำลังจะย้ายกลับบ้านว่าขายอุปกรณ์ไอทีที่ไหนในขอนแก่นได้ราคาดีและสะดวกสุด',
    tag: 'Local',
  },
  {
    href: '/blog/sell-iphone-before-new-model/',
    title: 'ก่อน iPhone รุ่นใหม่ออก ควรขายเครื่องเก่าตอนไหนให้เสียราคาน้อยลง',
    desc: 'วิเคราะห์วงจรราคา iPhone มือสองตลอดปี และช่วงเวลาที่ควรพิจารณาขายก่อนราคาตก',
    tag: 'Local',
  },
];

const tags = ['ทั้งหมด', 'GSC Query', 'เช็คราคา', 'ก่อนขาย', 'เปรียบเทียบ', 'Local'];

const displayLabels = {
  'GSC Query': 'คำถามยอดนิยม',
  'Local': 'ข้อมูลพื้นที่',
  'ทั้งหมด': 'ทั้งหมด',
  'เช็คราคา': 'เช็คราคา',
  'ก่อนขาย': 'ก่อนขาย',
  'เปรียบเทียบ': 'เปรียบเทียบ'
};
---

<Base title={title} description={description}>
  <main id="main-content">
    <section class="section">
      <div class="container blog-wrap">
        <p class="eyebrow">บทความ</p>
        <h1>ความรู้ก่อนขายของไอที ให้ได้ราคาเต็ม</h1>
        <p class="blog-sub">
          ทุกบทความเขียนจากประสบการณ์รับซื้อหน้างานจริงของทีม WINNER IT ขอนแก่น
          อัปเดตราคาและเทคนิคใหม่อยู่เสมอ
        </p>
        <div class="tag-list" role="list" aria-label="กรองตามหมวดหมู่">
          {tags.map((t) => (
            <span class="tag-chip">{displayLabels[t] || t}</span>
          ))}
        </div>
        <div class="post-list">
          {posts.map((p) => (
            <a href={p.href} class="card post-card">
              <span class="post-card__tag">{displayLabels[p.tag] || p.tag}</span>
              <h2>{p.title}</h2>
              <p>{p.desc}</p>
              <span class="post-card__more">อ่านต่อ →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
</Base>

<style>
  .blog-wrap { max-width: 900px; }
  .blog-sub { color: var(--ink-soft); margin-top: 10px; }
  .tag-list { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 20px; }
  .tag-chip {
    display: inline-block;
    padding: 4px 14px;
    border-radius: 99px;
    background: var(--mist);
    border: 1px solid var(--line);
    font-size: 0.85rem;
    color: var(--ink-soft);
    cursor: default;
  }
  .post-list { display: grid; gap: 16px; margin-top: 28px; }
  @media (min-width: 640px) {
    .post-list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 960px) {
    .post-list { grid-template-columns: repeat(3, 1fr); }
  }
  .post-card { display: block; color: var(--ink); }
  .post-card:hover { text-decoration: none; border-color: var(--volt); }
  .post-card__tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--volt);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 6px;
  }
  .post-card h2 { font-size: 1.05rem; line-height: 1.4; }
  .post-card p { color: var(--ink-soft); margin-top: 8px; font-size: 0.88rem; line-height: 1.5; }
  .post-card__more { display: inline-block; margin-top: 10px; color: var(--volt); font-weight: 600; font-size: 0.9rem; }
</style>
