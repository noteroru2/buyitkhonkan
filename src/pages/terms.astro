---
import Base from '../layouts/Base.astro';
import { SITE } from '../data/site.js';

const title = `ข้อกำหนดการใช้บริการ | ${SITE.name}`;
const description = `ข้อกำหนดการใช้เว็บไซต์และบริการรับซื้อสินค้าไอทีของ ${SITE.name} โดย ${SITE.company}`;
---

<Base title={title} description={description}>
  <main id="main-content" class="legal">
    <div class="container legal__in">
      <nav class="crumb" aria-label="breadcrumb">
        <a href="/">หน้าแรก</a> <span>/</span> ข้อกำหนดการใช้บริการ
      </nav>
      <h1>ข้อกำหนดการใช้บริการ</h1>
      <p class="lede">อัปเดตล่าสุด: 11 กรกฎาคม 2026 · {SITE.brandLine}</p>

      <h2>1. ขอบเขตบริการ</h2>
      <p>
        เว็บไซต์นี้ให้ข้อมูลเกี่ยวกับบริการประเมินและนัดรับซื้อสินค้าไอทีในจังหวัดขอนแก่น
        ภายใต้แบรนด์ {SITE.name} โดย {SITE.company}
        การใช้เว็บไซต์หรือการติดต่อผ่านช่องทางที่ระบุถือว่ายอมรับข้อกำหนดนี้
      </p>

      <h2>2. ข้อมูลบนเว็บไซต์</h2>
      <p>
        เนื้อหาและราคาอ้างอิงบนเว็บไซต์อาจเปลี่ยนแปลงได้โดยไม่ต้องแจ้งล่วงหน้า
        ไม่ถือเป็นข้อเสนอผูกพันจนกว่าจะมีการตรวจสภาพและตกลงรับซื้อจริง
      </p>

      <h2>3. การใช้ช่องทางติดต่อ</h2>
      <p>
        ช่องทางหลักคือโทรศัพท์ {SITE.phone} และ LINE {SITE.lineId}
        ผู้ใช้ไม่ควรส่งข้อมูลส่วนบุคคลหรือเอกสารเกินความจำเป็นก่อนได้รับการร้องขอ
      </p>

      <h2>4. ข้อจำกัดความรับผิด</h2>
      <p>
        เราไม่รับประกันอันดับการค้นหา ผลลัพธ์ทางธุรกิจ หรือราคาตลาดในอนาคต
        และไม่รับผิดชอบความเสียหายที่เกิดจากการใช้ข้อมูลบนเว็บไซต์โดยลำพังโดยไม่ตรวจสอบกับทีมงาน
      </p>

      <h2>5. กฎหมายที่ใช้</h2>
      <p>ข้อกำหนดนี้อยู่ภายใต้กฎหมายไทย หากมีส่วนใดใช้บังคับไม่ได้ ส่วนอื่นยังมีผลต่อไป</p>

      <p>
        รายละเอียดการรับซื้อดูที่<a href="/buyout-terms/">เงื่อนไขการรับซื้อ</a>
        และ<a href="/privacy/">นโยบายความเป็นส่วนตัว</a>
      </p>
    </div>
  </main>
</Base>

<style>
  .legal__in { max-width: 720px; padding-block: 48px 72px; }
  .crumb { font-size: 0.88rem; color: var(--ink-soft); margin-bottom: 18px; }
  .lede { font-size: 1.05rem; color: var(--ink-soft); margin: 14px 0 28px; }
  .legal h2 { margin: 28px 0 10px; }
  .legal p { color: #2b3547; margin-bottom: 12px; }
</style>
